{
  "name": "loqui",
  "version": "0.0.0",
  "private": true,
  "description": "Loqui — open-source, local-first meeting intelligence. Real-time dual-stream transcription, post-meeting diarization, AI chat & summaries, and an agent-queryable MCP server.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "mcp-server"
  ],
  "scripts": {
    "dev": "pnpm --filter @loqui/desktop dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "sidecar:dev": "uv run --project sidecar loqui-sidecar",
    "sidecar:test": "uv run --project sidecar pytest",
    "smoke:foundation": "node scripts/smoke-foundation.mjs",
    "smoke:audio": "node scripts/smoke-audio.mjs",
    "smoke:transcription": "node scripts/smoke-transcription.mjs",
    "smoke:meeting": "node scripts/smoke-meeting.mjs",
    "smoke:chat": "node scripts/smoke-chat.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.18.0"
  }
}
