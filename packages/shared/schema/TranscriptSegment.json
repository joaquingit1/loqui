{
  "$ref": "#/definitions/TranscriptSegment",
  "definitions": {
    "TranscriptSegment": {
      "type": "object",
      "properties": {
        "meetingId": {
          "type": "string",
          "format": "uuid"
        },
        "source": {
          "type": "string",
          "enum": [
            "mic",
            "system"
          ]
        },
        "text": {
          "type": "string",
          "default": ""
        },
        "tStart": {
          "type": "number",
          "default": 0
        },
        "tEnd": {
          "type": "number",
          "default": 0
        },
        "status": {
          "type": "string",
          "enum": [
            "partial",
            "final"
          ],
          "default": "partial"
        },
        "segId": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "meetingId",
        "source",
        "segId"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
