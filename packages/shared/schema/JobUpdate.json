{
  "$ref": "#/definitions/JobUpdate",
  "definitions": {
    "JobUpdate": {
      "type": "object",
      "properties": {
        "jobId": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "transcription",
            "diarization",
            "summary"
          ]
        },
        "state": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "done",
            "error",
            "canceled"
          ],
          "default": "queued"
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0
        },
        "error": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "required": [
        "jobId",
        "kind"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
