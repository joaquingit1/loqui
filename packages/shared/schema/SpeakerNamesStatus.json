{
  "$ref": "#/definitions/SpeakerNamesStatus",
  "definitions": {
    "SpeakerNamesStatus": {
      "type": "object",
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "disconnected",
            "connected",
            "capturing"
          ],
          "default": "disconnected"
        },
        "meetingActive": {
          "type": "boolean",
          "default": false
        },
        "bufferedEvents": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "lastEventAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "selectorVersion": {
          "type": "string",
          "default": ""
        },
        "extensionVersion": {
          "type": "string",
          "default": ""
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
