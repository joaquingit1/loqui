{
  "$ref": "#/definitions/SpeakerCorrelationResult",
  "definitions": {
    "SpeakerCorrelationResult": {
      "type": "object",
      "properties": {
        "meetingId": {
          "type": "string",
          "default": ""
        },
        "resolutions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "speaker": {
                "type": "string",
                "default": ""
              },
              "name": {
                "type": "string",
                "default": ""
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "default": 0
              },
              "support": {
                "type": "number",
                "minimum": 0,
                "default": 0
              },
              "apply": {
                "type": "boolean",
                "default": false
              }
            },
            "additionalProperties": false
          },
          "default": []
        },
        "participants": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "usedActivityEvents": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "coveragePct": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
