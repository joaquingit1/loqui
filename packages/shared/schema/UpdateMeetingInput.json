{
  "$ref": "#/definitions/UpdateMeetingInput",
  "definitions": {
    "UpdateMeetingInput": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "default": ""
        },
        "platform": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "google-meet",
                "zoom",
                "teams",
                "other"
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "startedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "endedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status": {
          "type": "string",
          "enum": [
            "recording",
            "processing",
            "done",
            "error"
          ],
          "default": "recording"
        },
        "participants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "default": ""
              },
              "name": {
                "type": "string",
                "default": ""
              },
              "speakerLabel": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              }
            },
            "additionalProperties": false
          },
          "default": []
        },
        "modelVersions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
