{
  "name": "@loqui/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/*": "./schema/*"
  },
  "files": [
    "dist",
    "schema",
    "src"
  ],
  "scripts": {
    "build": "tsc -b && node --import tsx scripts/emit-schema.ts",
    "emit-schema": "node --import tsx scripts/emit-schema.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8",
    "zod-to-json-schema": "^3.23.5"
  }
}
