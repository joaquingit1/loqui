{
  "name": "@loqui/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build:worklet": "node scripts/build-worklet.mjs",
    "dev": "pnpm build:worklet && electron-vite dev",
    "build": "pnpm build:worklet && electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "lint": "eslint . --max-warnings 0",
    "build:runtime": "node scripts/build-runtime.mjs",
    "package": "pnpm build:worklet && electron-vite build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || true"
  },
  "dependencies": {
    "@loqui/audio": "workspace:*",
    "@loqui/shared": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "docx": "^9.0.0",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "esbuild": "^0.21.5",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
