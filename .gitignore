dist/
out/
build/
*.tsbuildinfo
apps/desktop/dist/
apps/desktop/out/
packages/*/dist/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.uv/
*.egg-info/
sidecar/dist/
sidecar/build/

