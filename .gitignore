# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
out/
build/
*.tsbuildinfo
apps/desktop/dist/
apps/desktop/out/
packages/*/dist/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.uv/
*.egg-info/
sidecar/dist/
sidecar/build/

# Bundled / downloaded models (never commit)
models/
*.bin
*.ckpt
*.onnx
*.pt

# Local data
.loqui/
# Default LOQUI_DATA_DIR fallback (~/Loqui) lands here when ~/Loqui == repo root
# on a case-insensitive filesystem; never commit captured audio / meeting data.
meetings/
Loqui/
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
# Non-secret settings the app writes to its data dir (can land in the repo root
# in dev when the data dir resolves to cwd).
chat-settings.json

# Swift native helper build output (apps/desktop/native/macos)
.build/

# Secrets / config
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Packaging artifacts
*.dmg
*.zip
*.exe
*.app/
release/

# Playwright E2E artifacts
test-results/
playwright-report/
.playwright/

# stray uv/pytest temp dirs (created when tools run with a relative cache/tmp dir)
/tmp/
/.tmp/

# third-party design reference screenshots (not redistributed)
/docs/design/reference/
