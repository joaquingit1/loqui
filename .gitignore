# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
out/
build/
*.tsbuildinfo
apps/desktop/dist/
apps/desktop/out/
packages/*/dist/
# apps/desktop/build is electron-builder's buildResources dir: it holds COMMITTED
# source (app icons, the afterPack signing hook), not build output — so un-ignore
# the dir itself while still ignoring the staged-runtime output it also contains
# (build/runtime/ is populated by scripts/build-runtime.mjs at package time).
!apps/desktop/build/
apps/desktop/build/runtime/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.uv/
*.egg-info/
sidecar/dist/
sidecar/build/

# Bundled / downloaded models (never commit)
models/
*.bin
*.ckpt
*.onnx
*.pt

# Local data
.loqui/
# Default LOQUI_DATA_DIR fallback (~/Loqui) lands here when ~/Loqui == repo root
# on a case-insensitive filesystem; never commit captured audio / meeting data.
meetings/
Loqui/
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
# Non-secret settings the app writes to its data dir (can land in the repo root
# in dev when the data dir resolves to cwd).
chat-settings.json

# Swift native helper build output (apps/desktop/native/macos)
.build/

# Secrets / config
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Packaging artifacts
*.dmg
*.zip
*.exe
*.app/
release/
# electron-builder output dir (the .app/.dmg/.zip + blockmaps + builder-debug.yml)
dist-app/
# PyInstaller spec written to the repo root by build-runtime.mjs (regenerated each build)
/loqui-sidecar.spec

# Runtime state + SECRETS that can land in the repo root when the app/sidecar is
# run with cwd=repo (the real ones live under ~/Loqui). NEVER commit these —
# calendar-tokens.json holds OAuth access/refresh tokens.
/calendar-tokens.json
/app-settings.json

# Playwright E2E artifacts
test-results/
playwright-report/
.playwright/

# stray uv/pytest temp dirs (created when tools run with a relative cache/tmp dir)
/tmp/
/.tmp/

# Generated AudioWorklet bundle (built by scripts/build-worklet.mjs)
apps/desktop/src/renderer/public/capture-worklet.js
